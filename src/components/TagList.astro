---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<div class="flex flex-wrap gap-2">
  {
    tags.map((tag) => (
      <span class="rounded border border-[var(--color-line)] bg-[var(--color-paper)] px-2.5 py-1 text-xs font-semibold text-[var(--color-muted)]">
        {tag}
      </span>
    ))
  }
</div>

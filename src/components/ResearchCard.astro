---
import TagList from "./TagList.astro";
import Collaborators from "./Collaborators.astro";

interface Props {
  entry: {
    id: string;
    data: {
      title: string;
      summary: string;
      status: string;
      date: string;
      tags: string[];
      collaborators?: string[];
    };
  };
  basePath?: string;
  readMoreLabel?: string;
  collaboratorsLabel?: string;
}

const { entry, basePath = "/research", readMoreLabel = "Read more →", collaboratorsLabel = "With" } = Astro.props;
const href = `${basePath}/${entry.id}`;
---

<article class="rounded border border-[var(--color-line)] bg-[var(--color-paper)] p-5 transition-colors hover:border-[var(--color-accent)]">
  <div class="mb-4 flex flex-wrap items-center gap-2 text-xs font-bold uppercase tracking-[0.14em] text-[var(--color-accent)]">
    <span>{entry.data.status}</span>
    <span aria-hidden="true">/</span>
    <span>{entry.data.date}</span>
  </div>
  <h3 class="text-xl font-bold tracking-normal">
    <a href={href} class="hover:text-[var(--color-accent)]">{entry.data.title}</a>
  </h3>
  <p class="mt-3 text-sm text-[var(--color-muted)]">{entry.data.summary}</p>
  <div class="mt-5">
    <TagList tags={entry.data.tags} />
  </div>
  {entry.data.collaborators && entry.data.collaborators.length > 0 && (
    <div class="mt-4">
      <Collaborators names={entry.data.collaborators} label={collaboratorsLabel} />
    </div>
  )}
  <a class="mt-6 inline-flex text-sm font-bold text-[var(--color-accent)]" href={href}>{readMoreLabel}</a>
</article>

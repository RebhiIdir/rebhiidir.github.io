---
import { formspreeFormId } from "@data/contactForm";
import { useTranslations, type Locale } from "@i18n/ui";

interface Props {
  lang?: Locale;
}

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
---

<div class="rounded border border-[var(--color-line)] bg-[var(--color-paper)] p-5 md:col-span-2">
  <p class="text-sm font-bold uppercase tracking-[0.14em] text-[var(--color-accent)]">{t.contact.formTitle}</p>

  <form id="contact-form" class="mt-5 grid gap-4 sm:grid-cols-2" data-form-id={formspreeFormId}>
    <div>
      <label for="cf-name" class="mb-1 block text-xs font-bold text-[var(--color-muted)]">{t.contact.formName}</label>
      <input
        id="cf-name"
        name="name"
        type="text"
        required
        class="w-full rounded border border-[var(--color-line)] bg-[var(--color-subtle)] px-3 py-2 text-sm text-[var(--color-ink)] outline-none transition-colors focus:border-[var(--color-accent)]"
      />
    </div>
    <div>
      <label for="cf-email" class="mb-1 block text-xs font-bold text-[var(--color-muted)]">{t.contact.formEmail}</label>
      <input
        id="cf-email"
        name="email"
        type="email"
        required
        class="w-full rounded border border-[var(--color-line)] bg-[var(--color-subtle)] px-3 py-2 text-sm text-[var(--color-ink)] outline-none transition-colors focus:border-[var(--color-accent)]"
      />
    </div>
    <div class="sm:col-span-2">
      <label for="cf-message" class="mb-1 block text-xs font-bold text-[var(--color-muted)]">{t.contact.formMessage}</label>
      <textarea
        id="cf-message"
        name="message"
        rows="5"
        required
        class="w-full rounded border border-[var(--color-line)] bg-[var(--color-subtle)] px-3 py-2 text-sm text-[var(--color-ink)] outline-none transition-colors focus:border-[var(--color-accent)]"
      ></textarea>
    </div>

    <!-- Honeypot field: hidden from real visitors, catches simple spam bots -->
    <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

    <div class="flex flex-wrap items-center gap-4 sm:col-span-2">
      <button
        type="submit"
        id="cf-submit"
        class="relative inline-flex min-h-11 min-w-[9.5rem] items-center justify-center gap-2 overflow-hidden rounded border border-[var(--color-accent)] bg-[var(--color-accent)] px-5 text-sm font-bold transition-all duration-150 hover:opacity-90 active:scale-[0.96] disabled:cursor-not-allowed disabled:opacity-70 disabled:active:scale-100"
        style="color: var(--color-accent-contrast)"
      >
        <svg id="cf-spinner" class="hidden h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
          <path class="opacity-90" fill="currentColor" d="M4 12a8 8 0 0 1 8-8V0C5.4 0 0 5.4 0 12h4Z" />
        </svg>
        <svg id="cf-check" class="hidden h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
          <path d="m5 13 4 4L19 7" />
        </svg>
        <span id="cf-submit-label">{t.contact.formSend}</span>
      </button>

      <p
        id="cf-status"
        class="flex translate-y-1 items-center gap-2 text-sm font-medium opacity-0 transition-all duration-300"
        role="status"
        aria-live="polite"
      ></p>
    </div>
  </form>
</div>

<script define:vars={{ sendingLabel: t.contact.formSending, sendLabel: t.contact.formSend, successLabel: t.contact.formSuccess, errorLabel: t.contact.formError }}>
  const form = document.getElementById("contact-form");
  const status = document.getElementById("cf-status");
  const button = document.getElementById("cf-submit");
  const label = document.getElementById("cf-submit-label");
  const spinner = document.getElementById("cf-spinner");
  const check = document.getElementById("cf-check");

  function setStatus(text, kind) {
    status.textContent = text;
    status.style.color =
      kind === "success" ? "var(--color-accent)" : kind === "error" ? "#dc4747" : "var(--color-muted)";
    // restart the fade-in animation
    status.classList.remove("opacity-0", "translate-y-1");
    void status.offsetWidth;
    if (!text) {
      status.classList.add("opacity-0", "translate-y-1");
    }
  }

  function setBusy(isBusy) {
    button.disabled = isBusy;
    spinner.classList.toggle("hidden", !isBusy);
    label.classList.toggle("hidden", isBusy);
    if (isBusy) label.textContent = sendingLabel;
  }

  form.addEventListener("submit", async (event) => {
    event.preventDefault();

    // Simple honeypot: if this hidden field got filled, silently drop it.
    if (form._gotcha.value) return;

    const formId = form.dataset.formId;
    if (!formId || formId.startsWith("REPLACE_ME")) {
      setStatus(errorLabel, "error");
      return;
    }

    setBusy(true);
    check.classList.add("hidden");
    label.classList.remove("hidden");
    setStatus("", null);

    try {
      const response = await fetch(`https://formspree.io/f/${formId}`, {
        method: "POST",
        headers: { Accept: "application/json" },
        body: new FormData(form),
      });

      if (!response.ok) throw new Error("Request failed");

      setBusy(false);
      spinner.classList.add("hidden");
      check.classList.remove("hidden");
      label.textContent = sendLabel;
      setStatus(successLabel, "success");
      form.reset();

      setTimeout(() => check.classList.add("hidden"), 2500);
    } catch (err) {
      setBusy(false);
      label.textContent = sendLabel;
      setStatus(errorLabel, "error");
    }
  });
</script>

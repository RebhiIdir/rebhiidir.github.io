---
interface Props {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
}

const { href, label, variant = "secondary" } = Astro.props;
const classes =
  variant === "primary"
    ? "border-[var(--color-accent)] bg-[var(--color-accent)] text-white hover:bg-[#0a304b]"
    : "border-[var(--color-line)] bg-[var(--color-paper)] text-[var(--color-ink)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]";
---

<a
  href={href}
  class={`inline-flex min-h-11 items-center justify-center rounded border px-4 text-sm font-bold transition-colors ${classes}`}
>
  {label}
</a>

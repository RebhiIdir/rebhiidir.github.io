---
interface Props {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
  icon?: "github" | "linkedin" | "kaggle" | "download" | "mail" | "external";
}

const { href, label, variant = "secondary", icon } = Astro.props;
const classes =
  variant === "primary"
    ? "border-[var(--color-accent)] bg-[var(--color-accent)] text-[var(--color-accent-contrast)] hover:opacity-90"
    : "border-[var(--color-line)] bg-[var(--color-paper)] text-[var(--color-ink)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]";

// Internal links (relative paths within the site) open in the same tab.
// Everything else (http(s), mailto) opens in a new tab.
const isInternal = href.startsWith("/") || href.startsWith("#");
const target = isInternal ? undefined : "_blank";
const rel = isInternal ? undefined : "noopener noreferrer";

const icons: Record<string, string> = {
  github:
    '<path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.46-1.16-1.11-1.47-1.11-1.47-.9-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.9 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.56-1.11-4.56-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02a9.4 9.4 0 0 1 5 0c1.91-1.3 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.85v2.75c0 .26.18.57.69.48A10 10 0 0 0 12 2Z"/>',
  linkedin:
    '<path d="M6.94 8.5H3.56V21h3.38V8.5ZM5.25 3a2 2 0 1 0 0 4 2 2 0 0 0 0-4ZM21 21v-6.9c0-3.7-2-5.4-4.6-5.4a4 4 0 0 0-3.6 2v-1.7H9.44c.04.9 0 9.98 0 9.98h3.36v-6.98c0-.37.03-.75.14-1.02.3-.75 1-1.53 2.16-1.53 1.53 0 2.14 1.16 2.14 2.87V21H21Z"/>',
  kaggle:
    '<path d="M4 3h3.4v9.2l4.8-5.1h4.2l-5.6 5.7L17 20.9h-4.3l-4.3-6.3-1 1V21H4Zm14.6 0h1.9v17.9h-1.9Z"/>',
  download:
    '<path d="M12 3v11m0 0 4-4m-4 4-4-4M5 17v2a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-2"/>',
  mail: '<path d="M4 6h16v12H4Z"/><path d="m4 7 8 6 8-6"/>',
  external:
    '<path d="M14 4h6v6M20 4 10 14M9 5H6a2 2 0 0 0-2 2v11a2 2 0 0 0 2 2h11a2 2 0 0 0 2-2v-3"/>',
};

const iconPath = icon ? icons[icon] : null;
const strokeIcons = new Set(["download", "mail", "external"]);
---

<a
  href={href}
  target={target}
  rel={rel}
  class={`inline-flex min-h-11 items-center justify-center gap-2 rounded border px-4 text-sm font-bold transition-colors ${classes}`}
>
  {
    iconPath && (
      <svg
        viewBox="0 0 24 24"
        class="h-4 w-4 shrink-0"
        fill={strokeIcons.has(icon!) ? "none" : "currentColor"}
        stroke={strokeIcons.has(icon!) ? "currentColor" : "none"}
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        set:html={iconPath}
      />
    )
  }
  {label}
</a>

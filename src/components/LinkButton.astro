---
interface Props {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
  icon?: "github" | "linkedin" | "kaggle" | "download" | "mail" | "external";
}

const { href, label, variant = "secondary", icon } = Astro.props;
const classes =
  variant === "primary"
    ? "border-[var(--color-accent)] bg-[var(--color-accent)] hover:opacity-90"
    : "border-[var(--color-line)] bg-[var(--color-paper)] text-[var(--color-ink)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]";

// Anything that isn't a same-site page route (http(s) links, mailto, or a direct
// file download like a PDF) opens in a new tab.
const isFileDownload = /\.[a-z0-9]{2,5}$/i.test(href.split("?")[0].split("#")[0]);
const isInternalPage = (href.startsWith("/") || href.startsWith("#")) && !isFileDownload;
const target = isInternalPage ? undefined : "_blank";
const rel = isInternalPage ? undefined : "noopener noreferrer";

// Official brand marks (single-path, viewBox 0 0 24 24), same family as Simple Icons.
const icons: Record<string, string> = {
  github:
    '<path d="M12 .5C5.73.5.5 5.73.5 12c0 5.09 3.29 9.4 7.86 10.93.58.1.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.7-3.88-1.54-3.88-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.04-.72.08-.7.08-.7 1.15.08 1.76 1.19 1.76 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.56-.29-5.25-1.28-5.25-5.71 0-1.26.45-2.29 1.19-3.09-.12-.29-.52-1.47.11-3.06 0 0 .97-.31 3.18 1.18a11.1 11.1 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.77.12 3.06.74.8 1.18 1.83 1.18 3.09 0 4.44-2.7 5.42-5.27 5.7.42.36.79 1.08.79 2.17 0 1.57-.01 2.83-.01 3.22 0 .31.21.67.8.56A10.52 10.52 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5Z"/>',
  linkedin:
    '<path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.03-1.85-3.03-1.85 0-2.14 1.45-2.14 2.94v5.66H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0Z"/>',
  kaggle:
    '<path d="M18.83 21.53h-3.4l-6.14-7.94-1.83 1.75v6.19H4.72V2.47h2.74v10.42l7.44-7.9h3.31l-6.87 7.25 7.49 9.29Z"/>',
  download:
    '<path d="M12 3v11m0 0 4-4m-4 4-4-4M5 17v2a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-2"/>',
  mail: '<path d="M4 6h16v12H4Z"/><path d="m4 7 8 6 8-6"/>',
  external:
    '<path d="M14 4h6v6M20 4 10 14M9 5H6a2 2 0 0 0-2 2v11a2 2 0 0 0 2 2h11a2 2 0 0 0 2-2v-3"/>',
};

const iconPath = icon ? icons[icon] : null;
const strokeIcons = new Set(["download", "mail", "external"]);
const textStyle = variant === "primary" ? "color: var(--color-accent-contrast)" : undefined;
---

<a
  href={href}
  target={target}
  rel={rel}
  style={textStyle}
  class={`inline-flex min-h-11 items-center justify-center gap-2 rounded border px-4 text-sm font-bold transition-colors ${classes}`}
>
  {
    iconPath && (
      <svg
        viewBox="0 0 24 24"
        class="h-4 w-4 shrink-0"
        fill={strokeIcons.has(icon!) ? "none" : "currentColor"}
        stroke={strokeIcons.has(icon!) ? "currentColor" : "none"}
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        set:html={iconPath}
      />
    )
  }
  {label}
</a>

---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="max-w-3xl">
  {eyebrow && <p class="mb-2 text-xs font-bold uppercase tracking-[0.18em] text-[var(--color-accent)]">{eyebrow}</p>}
  <h2 class="text-2xl font-bold tracking-normal text-[var(--color-ink)] sm:text-3xl">{title}</h2>
  {description && <p class="mt-3 text-base text-[var(--color-muted)]">{description}</p>}
</div>

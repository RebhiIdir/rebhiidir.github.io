---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import LinkButton from "@components/LinkButton.astro";
import SectionHeading from "@components/SectionHeading.astro";
import TagList from "@components/TagList.astro";
import { profile } from "@data/profile";
---

<BaseLayout title={`CV - ${profile.name}`}>
  <Container class="py-16 sm:py-20">
    <SectionHeading
      eyebrow="CV"
      title="Curriculum Vitae"
      description="Master's student in Intelligent Computer Systems — machine learning, computer vision, and steganalysis of generative AI."
    />

    {
      profile.cvPdfUrl ? (
        <div class="mt-8">
          <LinkButton href={profile.cvPdfUrl} label="Download PDF" variant="primary" />
        </div>
      ) : (
        <p class="mt-8 max-w-2xl rounded border border-[var(--color-line)] bg-[var(--color-subtle)] p-4 text-sm text-[var(--color-muted)]">
          Add your PDF file in public/documents, then set cvPdfUrl in src/data/profile.ts.
        </p>
      )
    }

    <div class="mt-12 grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <aside class="space-y-6">
        <div class="rounded border border-[var(--color-line)] bg-[var(--color-subtle)] p-5">
          <p class="font-bold">Core skills</p>
          <div class="mt-4">
            <TagList
              tags={[
                "Python",
                "PyTorch / TensorFlow",
                "Machine Learning",
                "Computer Vision",
                "Diffusion Models",
                "Java (Spring, JAX-RS, Android)",
                "C (systems)",
                "SQL / MySQL",
                "Apache Hadoop & Spark",
                "Git & GitHub",
              ]}
            />
          </div>
        </div>

        <div class="rounded border border-[var(--color-line)] bg-[var(--color-subtle)] p-5">
          <p class="font-bold">Languages</p>
          <ul class="mt-3 space-y-1 text-sm text-[var(--color-muted)]">
            <li>Kabyle — native</li>
            <li>French — C1 (TCF)</li>
            <li>Arabic — fluent</li>
            <li>English — fluent</li>
          </ul>
        </div>

        <div class="rounded border border-[var(--color-line)] bg-[var(--color-subtle)] p-5">
          <p class="font-bold">Certifications</p>
          <ul class="mt-3 space-y-1 text-sm text-[var(--color-muted)]">
            <li>CCNA: Introduction to Networks</li>
            <li>Endpoint Security</li>
          </ul>
        </div>

        <div class="rounded border border-[var(--color-line)] bg-[var(--color-subtle)] p-5">
          <p class="font-bold">Interests</p>
          <ul class="mt-3 space-y-1 text-sm text-[var(--color-muted)]">
            <li>Piano — arranging film and game scores</li>
            <li>Football and cycling</li>
            <li>Graphic design (Inkscape, Krita) and video editing (Kdenlive)</li>
          </ul>
        </div>
      </aside>

      <div class="content-prose">
        <h2>Education</h2>
        <p><strong>Master 2, Intelligent Computer Systems</strong> — Université Mouloud Mammeri de Tizi-Ouzou (2025–2026, in progress)</p>
        <p><strong>Master 1, Intelligent Computer Systems</strong> — Université Mouloud Mammeri de Tizi-Ouzou (2024–2025)</p>
        <p><strong>Licence (Bachelor) in Computer Science</strong> — Université Mouloud Mammeri de Tizi-Ouzou (2022–2024)</p>
        <p><strong>L1, Mathematics and Computer Science</strong> — Université Mouloud Mammeri de Tizi-Ouzou (2021–2022)</p>
        <p><strong>Baccalauréat, Scientific stream</strong>, Mention Bien — Lycée Frères Abbache, Mekla, Tizi-Ouzou (2021)</p>

        <h2>Research</h2>
        <p>
          <strong>Master's thesis (2025–2026):</strong> "Detecting steganography from generative models:
          distinguishing steganographic images from synthetic images." Co-authored with Siham Larbi, supervised
          by M. Samy Sadi and Mlle. Hedir Tassadit, Université Mouloud Mammeri de Tizi-Ouzou.
        </p>
        <p>
          Re-implemented and evaluated the NS-DSer steganalysis baseline on Stable Diffusion 2.1, then extended
          it with a CNN-based classifier and additional statistical/RPCM features to test detection against
          distribution-preserving techniques such as mas-GRDH and Gaussian Shading. Full write-up on the{" "}
          <a href="/research/generative-steganography">Research</a> page — code, notebooks, and datasets are
          public on GitHub, Kaggle, and Colab.
        </p>

        <h2>Technical experience</h2>
        <p><strong>Internship, District Commercial Naftal, Tizi-Ouzou (2024)</strong> — understanding the role of IT within a company; assessment of business processes, information systems, and management workflows; internship report.</p>
        <p><strong>Bachelor's final project (L3, 2024)</strong> — management application for an industrial oil mill (Python/PyQt5, Qt Designer, MySQL), built in pair, with UML modeling and a written thesis.</p>
        <p>Selected Master's and personal projects — see the <a href="/projects">Projects</a> page for details and links:</p>
        <ul>
          <li>NS-DSer steganalysis pipeline — PF-ODE inversion, dual-GPU Kaggle setup, FLD Ensemble classifier (99.52% accuracy, AUC-ROC 1.0)</li>
          <li>REST API for medical office management (Java, Spring, MySQL, JWT, Postman)</li>
          <li>Smart lighting IoT system (ESP32, Raspberry Pi, Grafana)</li>
          <li>Facial recognition system (feature extraction, model training, evaluation)</li>
          <li>Image generation with a GAN on MNIST (TensorFlow)</li>
          <li>Character recognition with KNN and CNN</li>
          <li>Phylogenetic tree construction (bioinformatics)</li>
          <li>Cinema ontology for the semantic web</li>
          <li>2D game prototype in Godot Engine (C#/GDScript) — in progress</li>
        </ul>

        <h2>Publications</h2>
        <p>
          No publications yet. This section will be updated as the thesis work leads to conference or journal
          submissions.
        </p>
      </div>
    </div>
  </Container>
</BaseLayout>

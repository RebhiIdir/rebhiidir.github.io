---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import SectionHeading from "@components/SectionHeading.astro";
import LinkButton from "@components/LinkButton.astro";
import TagList from "@components/TagList.astro";
import { profile } from "@data/profile";
import { useTranslations } from "@i18n/ui";

const t = useTranslations("en");
---

<BaseLayout title={`CV - ${profile.name}`}>
  <Container class="py-16 sm:py-20">
    <SectionHeading eyebrow={t.cv.eyebrow} title={t.cv.title} description={t.cv.description} />

    <div class="mt-8">
      <LinkButton href={profile.cvPdfUrl} label={t.cv.download} variant="primary" />
    </div>

    <div class="mt-12 grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <aside class="space-y-6">
        <div class="rounded border border-[var(--color-line)] bg-[var(--color-subtle)] p-5">
          <p class="font-bold">{t.cv.coreSkills}</p>
          <div class="mt-4">
            <TagList
              tags={[
                "Machine Learning",
                "Deep Learning",
                "Computer Vision",
                "NLP",
                "Generative AI",
                "PyTorch / TensorFlow",
                "Scikit-learn / Diffusers",
                "Stable Diffusion pipelines",
              ]}
            />
          </div>
        </div>

        <div class="rounded border border-[var(--color-line)] bg-[var(--color-subtle)] p-5">
          <p class="font-bold">Libraries &amp; tools</p>
          <div class="mt-4">
            <TagList
              tags={[
                "PyTorch",
                "TensorFlow",
                "Scikit-learn",
                "Diffusers",
                "OpenCV",
                "NLTK",
                "NumPy",
                "Pandas",
                "Matplotlib",
                "Git & GitHub",
                "Jupyter Notebook",
                "Google Colab",
                "Kaggle",
                "LaTeX",
                "Linux/Bash",
              ]}
            />
          </div>
        </div>

        <div class="rounded border border-[var(--color-line)] bg-[var(--color-subtle)] p-5">
          <p class="font-bold">Mathematics</p>
          <div class="mt-4">
            <TagList tags={["Linear Algebra", "Differential Calculus", "Probability & Statistics", "Optimization"]} />
          </div>
        </div>

        <div class="rounded border border-[var(--color-line)] bg-[var(--color-subtle)] p-5">
          <p class="font-bold">{t.cv.languages}</p>
          <ul class="mt-3 space-y-1 text-sm text-[var(--color-muted)]">
            <li>Kabyle — native</li>
            <li>French — C1 (TCF)</li>
            <li>Arabic — fluent</li>
            <li>English — fluent</li>
          </ul>
        </div>

        <div class="rounded border border-[var(--color-line)] bg-[var(--color-subtle)] p-5">
          <p class="font-bold">{t.cv.certifications}</p>
          <ul class="mt-3 space-y-1 text-sm text-[var(--color-muted)]">
            <li>CCNA: Introduction to Networks</li>
            <li>Endpoint Security</li>
          </ul>
        </div>
      </aside>

      <div class="content-prose">
        <h2>{t.cv.education}</h2>
        <p><strong>Master's Degree, Intelligent Computer Systems</strong> — Mouloud Mammeri University of Tizi-Ouzou (2024–2026)</p>
        <p><strong>Bachelor's Degree in Computer Science</strong> — Mouloud Mammeri University of Tizi-Ouzou (2022–2024)</p>
        <p><strong>First Year, Mathematics and Computer Science</strong> — Mouloud Mammeri University of Tizi-Ouzou (2021–2022)</p>
        <p><strong>Scientific Baccalaureate</strong>, Honours — Frères Abbache High School, Mekla (2021)</p>

        <h2>{t.cv.research}</h2>
        <p>
          <strong>Master's Research Project (2026):</strong> "Detection of Generative Steganography: Distinguishing
          Steganographic Images from Synthetic Images." Carried out with Siham Larbi, supervised by M. Samy Sadi
          and Mlle. Hedir Tassadit, Université Mouloud Mammeri de Tizi-Ouzou.
        </p>
        <ul>
          <li>Diffusion-model-based approach</li>
          <li>Creation and organization of a dedicated dataset</li>
          <li>Design of an inversion pipeline using Stable Diffusion</li>
          <li>Experimental reproduction of a state-of-the-art method (NS-DSer)</li>
          <li>Development of a Deep Learning approach</li>
          <li>Training and evaluation of classifiers (CNN, SVM, Random Forest, FLD, etc.)</li>
          <li>Performance evaluation and experimental analysis</li>
        </ul>
        <p>Full write-up on the <a href="/research/generative-steganography">Research</a> page.</p>

        <h2>{t.cv.technicalExperience}</h2>
        <p><strong>Computer Science Internship, District Commercial Naftal, Tizi-Ouzou (2024)</strong> — analysis of the company's information system, business process evaluation, study of enterprise information management, technical internship report.</p>
        <p><strong>Bachelor's final project (2024)</strong> — Industrial Oil Mill Management Application (Python/PyQt5, Qt Designer, MySQL), with Siham Larbi: UML modeling and a written dissertation.</p>
        <p>Selected applied Master's and personal projects — see the <a href="/projects">Projects</a> page for details, collaborators, and links.</p>

        <h2>{t.cv.publications}</h2>
        <p>No publications yet. This section will be updated as the thesis work leads to conference or journal submissions.</p>
      </div>
    </div>
  </Container>
</BaseLayout>

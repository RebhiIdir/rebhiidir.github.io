---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import LinkButton from "@components/LinkButton.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { profile } from "@data/profile";
---

<BaseLayout title={`Contact - ${profile.name}`}>
  <Container class="py-16 sm:py-20">
    <SectionHeading
      eyebrow="Contact"
      title="Contact and academic links"
      description="Use this page for direct contact and profiles that show code, projects, datasets, or public work."
    />

    <div class="mt-10 grid gap-5 md:grid-cols-2">
      <div class="rounded border border-[var(--color-line)] bg-white p-5">
        <p class="text-sm font-bold uppercase tracking-[0.14em] text-[var(--color-accent)]">Email</p>
        <h2 class="mt-3 text-2xl font-bold">Research contact</h2>
        <p class="mt-3 text-[var(--color-muted)]">
          For research discussions, internships, thesis supervision, or collaboration opportunities.
        </p>
        <div class="mt-6">
          <LinkButton href={`mailto:${profile.email}`} label={profile.email} variant="primary" />
        </div>
      </div>

      <div class="rounded border border-[var(--color-line)] bg-[var(--color-subtle)] p-5">
        <p class="text-sm font-bold uppercase tracking-[0.14em] text-[var(--color-accent)]">Profiles</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <LinkButton href={profile.links.github} label="GitHub" />
          <LinkButton href={profile.links.kaggle} label="Kaggle" />
          <LinkButton href={profile.links.linkedin} label="LinkedIn" />
        </div>
      </div>
    </div>
  </Container>
</BaseLayout>

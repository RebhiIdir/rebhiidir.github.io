---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import LinkButton from "@components/LinkButton.astro";
import ProjectCard from "@components/ProjectCard.astro";
import ResearchCard from "@components/ResearchCard.astro";
import SectionHeading from "@components/SectionHeading.astro";
import TagList from "@components/TagList.astro";
import { profile } from "@data/profile";
import { useTranslations } from "@i18n/ui";

const lang = "en" as const;
const t = useTranslations(lang);

const research = (await getCollection("research"))
  .filter((entry) => entry.data.featured)
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const projects = (await getCollection("projects"))
  .filter((entry) => entry.data.featured)
  .sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<BaseLayout>
  <Container class="py-16 sm:py-24">
    <section class="grid gap-12 lg:grid-cols-[1.2fr_0.8fr] lg:items-start">
      <div>
        <p class="mb-4 text-sm font-bold uppercase tracking-[0.18em] text-[var(--color-accent)]">{profile.title}</p>
        <h1 class="max-w-4xl text-5xl font-bold leading-tight tracking-normal text-[var(--color-ink)] sm:text-6xl">
          {profile.name}
        </h1>
        <p class="mt-6 max-w-2xl text-lg text-[var(--color-muted)]">{profile.subtitle}</p>

        <div class="mt-8 flex flex-wrap gap-3">
          <LinkButton href={profile.cvPageUrl} label={t.home.viewCv} variant="primary" icon="external" />
          <LinkButton href={profile.links.github} label="GitHub" icon="github" />
          <LinkButton href={profile.links.kaggle} label="Kaggle" icon="kaggle" />
          <LinkButton href={profile.links.linkedin} label="LinkedIn" icon="linkedin" />
        </div>
      </div>

      <aside class="rounded border border-[var(--color-line)] bg-[var(--color-subtle)] p-5">
        <p class="text-sm font-bold text-[var(--color-ink)]">{t.home.researchInterests}</p>
        <div class="mt-4">
          <TagList tags={profile.researchInterests} />
        </div>
        <div class="mt-6 border-t border-[var(--color-line)] pt-5">
          <p class="text-sm font-bold text-[var(--color-ink)]">Quick Facts</p>
          <ul class="mt-3 space-y-2 text-sm text-[var(--color-muted)]">
            {profile.quickFacts.map((fact) => <li>{fact}</li>)}
          </ul>
        </div>
      </aside>
    </section>
  </Container>

  <section class="border-y border-[var(--color-line)] bg-[var(--color-subtle)] py-16">
    <Container>
      <SectionHeading
        eyebrow={t.research.eyebrow}
        title={t.home.highlights}
        description="A focused view of the topics that define the research identity of this portfolio."
      />
      <div class="mt-8 grid gap-5 md:grid-cols-2">
        {research.map((entry) => <ResearchCard entry={entry} readMoreLabel={t.research.readMore} collaboratorsLabel={t.research.collaborators} />)}
      </div>
    </Container>
  </section>

  <section class="py-16">
    <Container>
      <SectionHeading
        eyebrow="Engineering"
        title={t.home.latestProjects}
        description="Selected applied projects that support the research profile with working systems and code."
      />
      <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {projects.map((entry) => <ProjectCard entry={entry} viewLabel={t.projects.viewProject} collaboratorsLabel={t.projects.collaborators} />)}
      </div>
    </Container>
  </section>
</BaseLayout>

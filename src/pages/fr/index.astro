---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import LinkButton from "@components/LinkButton.astro";
import ProjectCard from "@components/ProjectCard.astro";
import ResearchCard from "@components/ResearchCard.astro";
import SectionHeading from "@components/SectionHeading.astro";
import TagList from "@components/TagList.astro";
import { profile } from "@data/profile";
import { useTranslations } from "@i18n/ui";

const lang = "fr" as const;
const t = useTranslations(lang);

const research = (await getCollection("researchFr"))
  .filter((entry) => entry.data.featured)
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const projects = (await getCollection("projectsFr"))
  .filter((entry) => entry.data.featured)
  .sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<BaseLayout title={`${profile.name} - ${profile.title}`} description={profile.subtitleFr}>
  <Container class="py-16 sm:py-24">
    <section class="grid gap-12 lg:grid-cols-[1.2fr_0.8fr] lg:items-start">
      <div>
        <p class="mb-4 text-sm font-bold uppercase tracking-[0.18em] text-[var(--color-accent)]">{profile.title}</p>
        <h1 class="max-w-4xl text-5xl font-bold leading-tight tracking-normal text-[var(--color-ink)] sm:text-6xl">
          {profile.name}
        </h1>
        <p class="mt-6 max-w-2xl text-lg text-[var(--color-muted)]">{profile.subtitleFr}</p>

        <div class="mt-8 flex flex-wrap gap-3">
          <LinkButton href={profile.cvPageUrl.replace("/cv", "/fr/cv")} label={t.home.viewCv} variant="primary" icon="external" />
          <LinkButton href={profile.links.github} label="GitHub" icon="github" />
          <LinkButton href={profile.links.kaggle} label="Kaggle" icon="kaggle" />
          <LinkButton href={profile.links.linkedin} label="LinkedIn" icon="linkedin" />
        </div>
      </div>

      <aside class="rounded border border-[var(--color-line)] bg-[var(--color-subtle)] p-5">
        <p class="text-sm font-bold text-[var(--color-ink)]">{t.home.researchInterests}</p>
        <div class="mt-4">
          <TagList tags={profile.researchInterestsFr} />
        </div>
        <div class="mt-6 border-t border-[var(--color-line)] pt-5">
          <p class="text-sm font-bold text-[var(--color-ink)]">En bref</p>
          <ul class="mt-3 space-y-2 text-sm text-[var(--color-muted)]">
            {profile.quickFactsFr.map((fact) => <li>{fact}</li>)}
          </ul>
        </div>
      </aside>
    </section>
  </Container>

  <section class="border-y border-[var(--color-line)] bg-[var(--color-subtle)] py-16">
    <Container>
      <SectionHeading
        eyebrow={t.research.eyebrow}
        title={t.home.highlights}
        description="Un aperçu ciblé des sujets qui définissent l'identité de recherche de ce portfolio."
      />
      <div class="mt-8 grid gap-5 md:grid-cols-2">
        {research.map((entry) => <ResearchCard entry={entry} basePath="/fr/research" readMoreLabel={t.research.readMore} collaboratorsLabel={t.research.collaborators} />)}
      </div>
    </Container>
  </section>

  <section class="py-16">
    <Container>
      <SectionHeading
        eyebrow="Ingénierie"
        title={t.home.latestProjects}
        description="Une sélection de projets appliqués qui accompagnent le profil de recherche avec des systèmes et du code fonctionnels."
      />
      <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {projects.map((entry) => <ProjectCard entry={entry} basePath="/fr/projects" viewLabel={t.projects.viewProject} collaboratorsLabel={t.projects.collaborators} />)}
      </div>
    </Container>
  </section>
</BaseLayout>

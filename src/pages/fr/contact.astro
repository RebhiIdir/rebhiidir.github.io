---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import LinkButton from "@components/LinkButton.astro";
import SectionHeading from "@components/SectionHeading.astro";
import ContactForm from "@components/ContactForm.astro";
import { profile } from "@data/profile";
import { useTranslations } from "@i18n/ui";

const t = useTranslations("fr");
---

<BaseLayout title={`Contact - ${profile.name}`} description={profile.subtitleFr}>
  <Container class="py-16 sm:py-20">
    <SectionHeading eyebrow={t.contact.eyebrow} title={t.contact.title} description={t.contact.description} />

    <div class="mt-10 grid gap-5 md:grid-cols-2">
      <div class="rounded border border-[var(--color-line)] bg-[var(--color-paper)] p-5">
        <p class="text-sm font-bold uppercase tracking-[0.14em] text-[var(--color-accent)]">{t.contact.emailLabel}</p>
        <h2 class="mt-3 text-2xl font-bold">{t.contact.emailTitle}</h2>
        <p class="mt-3 text-[var(--color-muted)]">{t.contact.emailBody}</p>
        <div class="mt-6">
          <LinkButton href={`mailto:${profile.email}`} label={profile.email} variant="primary" icon="mail" />
        </div>
      </div>

      <div class="rounded border border-[var(--color-line)] bg-[var(--color-subtle)] p-5">
        <p class="text-sm font-bold uppercase tracking-[0.14em] text-[var(--color-accent)]">{t.contact.profiles}</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <LinkButton href={profile.links.github} label="GitHub" icon="github" />
          <LinkButton href={profile.links.kaggle} label="Kaggle" icon="kaggle" />
          <LinkButton href={profile.links.linkedin} label="LinkedIn" icon="linkedin" />
        </div>
      </div>
    </div>

    <div class="mt-5 max-w-2xl">
      <ContactForm lang="fr" />
    </div>
  </Container>
</BaseLayout>

---
import { getCollection, render } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import LinkButton from "@components/LinkButton.astro";
import TagList from "@components/TagList.astro";
import Collaborators from "@components/Collaborators.astro";
import { profile } from "@data/profile";
import { useTranslations } from "@i18n/ui";

export async function getStaticPaths() {
  const entries = await getCollection("projectsFr");

  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const t = useTranslations("fr");
const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={`${entry.data.title} - ${profile.name}`} description={entry.data.summary}>
  <Container class="py-16 sm:py-20">
    <article class="mx-auto max-w-4xl">
      <a href="/fr/projects" class="text-sm font-bold text-[var(--color-accent)]">{t.projects.back}</a>
      <div class="mt-8">
        <p class="mb-4 text-sm font-bold uppercase tracking-[0.18em] text-[var(--color-accent)]">{entry.data.date}</p>
        <h1 class="text-4xl font-bold leading-tight tracking-normal sm:text-5xl">{entry.data.title}</h1>
        <p class="mt-5 text-lg text-[var(--color-muted)]">{entry.data.summary}</p>
        <div class="mt-6">
          <TagList tags={entry.data.technologies} />
        </div>
        {entry.data.collaborators.length > 0 && (
          <div class="mt-4">
            <Collaborators names={entry.data.collaborators} label={t.projects.collaborators} />
          </div>
        )}
      </div>

      {
        entry.data.links.length > 0 && (
          <div class="mt-8 flex flex-wrap gap-3">
            {entry.data.links.map((link, index) => (
              <LinkButton href={link.url} label={link.label} variant={index === 0 ? "primary" : "secondary"} />
            ))}
          </div>
        )
      }

      <div class="content-prose mt-10">
        <Content />
      </div>
    </article>
  </Container>
</BaseLayout>
